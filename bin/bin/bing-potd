const BING =
  'https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=1&mkt=en-US'
const PICTURES = path.resolve(os.homedir(), 'Pictures/Wallpapers/Bing')

async function main() {
  const {
    images: [{startdate, urlbase}],
  } = await fetch(BING).then(r => r.json())
  const suffix = '_UHD.jpg'
  const url = new URL(`${urlbase}${suffix}`, BING)
  const id = url.searchParams.get('id')
  const filepath = path.resolve(PICTURES, `${startdate}-${id.replace(/^OHR[.]/, '')}`)
  if (!await fs.access(filepath).catch(() => false)) {
    await download(url, filepath)
  }
  const today = path.resolve(path.dirname(filepath), 'today.jpg')
  await fs.unlink(today)
  await fs.symlink(path.basename(filepath), today)
}

async function download(url, filepath) {
  const response = await fetch(url)
  if (!response.ok) throw new Error(`Failed to fetch (${response.status})`)
  const buffer = Buffer.from(await response.arrayBuffer())
  await fs.writeFile(filepath, buffer)
}

main()
